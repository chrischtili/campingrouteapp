# Compression (Gzip)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json
</IfModule>

# Canonical host + HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\.campingroute\.app$ [NC]
  RewriteRule ^(.*)$ https://campingroute.app/$1 [L,R=301]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images: 1 Year
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # Video: 1 Year
  ExpiresByType video/mp4 "access plus 1 year"
  
  # CSS / JS: 1 Year (Safe because Vite hashes filenames)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  
  # Fonts: 1 Year
  ExpiresByType font/truetype "access plus 1 year"
  ExpiresByType font/opentype "access plus 1 year"
  ExpiresByType application/x-font-woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"

  # HTML: always revalidate
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/xhtml+xml "access plus 0 seconds"
  
  # Default: 1 Month
  ExpiresDefault "access plus 1 month"
</IfModule>

# Fine-grained cache headers
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  <Files "version.json">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  </Files>
</IfModule>

# Block sensitive files if they ever end up on the server
<FilesMatch "^(\.env|\.env\..*|composer\.(json|lock)|package(-lock)?\.json)$">
  Require all denied
</FilesMatch>
